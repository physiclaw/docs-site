---
// Override of Starlight's Head that adds Astro's ClientRouter, turning
// page-to-page navigation into in-place view transitions (a smooth cross-fade)
// instead of a full hard reload.
import Default from '@astrojs/starlight/components/Head.astro';
import { ClientRouter } from 'astro:transitions';
---

<Default><slot /></Default>
<ClientRouter />

{/* View-transition polish. Inlined so it runs immediately; the document-level
   listeners persist across swaps (the document is never replaced). */}
<script is:inline>
  (() => {
    /** Resolve the user's theme: explicit choice, else system preference. */
    const resolveTheme = () => {
      const stored = localStorage.getItem('starlight-theme');
      if (stored === 'light' || stored === 'dark') return stored;
      return matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    };

    // The router copies the incoming page's <html> attributes over the current
    // ones, stripping the client-set data-theme (it reverts to dark). Write the
    // theme onto the INCOMING document before the swap, so it's already correct
    // when applied — no flash of the wrong theme.
    document.addEventListener('astro:before-swap', (e) => {
      e.newDocument.documentElement.dataset.theme = resolveTheme();
    });

    // Our global `scroll-behavior: smooth` (for TOC anchors) would also animate
    // the router's scroll-to-top on navigation. Force instant scrolling for the
    // duration of the swap, then restore smooth for same-page anchor clicks.
    document.addEventListener('astro:before-swap', () => {
      document.documentElement.style.scrollBehavior = 'auto';
    });
    document.addEventListener('astro:page-load', () => {
      document.documentElement.style.removeProperty('scroll-behavior');
    });
  })();
</script>
