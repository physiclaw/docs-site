---
// Build-photo gallery body, shared by the en + zh pages (see src/pages/*/hardware-gallery).
//
// Photos are fetched into src/assets/gallery/ at build time by scripts/fetch-release.mjs
// and optimized here with astro:assets (sharp): a small webp thumbnail per photo plus a
// larger webp for the lightbox, so big originals never block the grid. The masonry
// layout keeps each photo's natural aspect ratio (no cropping). The lightbox is a
// small progressive enhancement (script below): it adds ONE history entry for the
// whole viewing session — prev/next swap in place, Back/Esc/× close it — so browsing
// photos never traps the browser's Back button. Without JS, thumbnails just link to
// the full image.
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  lang?: 'en' | 'zh';
}
const { lang = 'en' } = Astro.props;

const STRINGS = {
  en: {
    intro: 'Real build photos of an assembled PhysiClaw rig.',
    empty: 'Gallery photos are being prepared — check back soon.',
    alt: (n: number) => `Assembled PhysiClaw rig — photo ${n}`,
    enlarge: (n: number) => `View photo ${n} full size`,
    prev: 'Previous photo',
    next: 'Next photo',
    close: 'Close',
  },
  zh: {
    intro: '组装完成的 PhysiClaw 硬件实物照片。',
    empty: '相册照片正在准备中，敬请期待。',
    alt: (n: number) => `已组装的 PhysiClaw — 照片 ${n}`,
    enlarge: (n: number) => `查看第 ${n} 张大图`,
    prev: '上一张',
    next: '下一张',
    close: '关闭',
  },
}[lang];

// Eagerly import every gallery image as ImageMetadata (width/height/format).
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.{png,jpg,jpeg,webp,avif,gif}',
  { eager: true },
);
const sources = Object.keys(modules)
  .sort()
  .map((k) => modules[k].default);

// Pre-render an optimized thumbnail + lightbox image for each photo.
const photos = await Promise.all(
  sources.map(async (src, i) => {
    const n = i + 1;
    const thumbW = Math.min(src.width, 900);
    const fullW = Math.min(src.width, 2000);
    const [thumb, full] = await Promise.all([
      getImage({ src, width: thumbW, format: 'webp' }),
      getImage({ src, width: fullW, format: 'webp' }),
    ]);
    return {
      n,
      thumbSrc: thumb.src,
      thumbW,
      thumbH: Math.round((thumbW * src.height) / src.width),
      fullSrc: full.src,
    };
  }),
);
---

{
  photos.length === 0 ? (
    <p class="gallery-empty">{STRINGS.empty}</p>
  ) : (
    <Fragment>
      <p class="gallery-intro">{STRINGS.intro}</p>

      {/* Thumbnails link to the full image (no-JS fallback); the script below
          intercepts the click and opens the in-page lightbox instead. */}
      <div class="gallery-masonry" data-gallery>
        {photos.map((p) => (
          <a class="gallery-item" href={p.fullSrc} aria-label={STRINGS.enlarge(p.n)}>
            <img
              src={p.thumbSrc}
              width={p.thumbW}
              height={p.thumbH}
              alt={STRINGS.alt(p.n)}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>

      {/* Single reusable lightbox, driven by the script (no URL hash, so browsing
          photos never pollutes browser history). */}
      <div class="gallery-lightbox" data-lightbox role="dialog" aria-modal="true" aria-label="Photo viewer">
        <button type="button" class="lb-backdrop" data-lb-close aria-label={STRINGS.close} />
        <button type="button" class="lb-nav lb-prev" data-lb-prev aria-label={STRINGS.prev}>‹</button>
        <img class="lb-img" data-lb-img alt="" />
        <button type="button" class="lb-nav lb-next" data-lb-next aria-label={STRINGS.next}>›</button>
        <button type="button" class="lb-close" data-lb-close aria-label={STRINGS.close}>×</button>
        <span class="lb-counter" data-lb-counter />
      </div>

      <script>
        const grid = document.querySelector<HTMLElement>('[data-gallery]');
        const box = document.querySelector<HTMLElement>('[data-lightbox]');
        if (grid && box) {
          const view = box.querySelector<HTMLImageElement>('[data-lb-img]')!;
          const counter = box.querySelector<HTMLElement>('[data-lb-counter]')!;
          const links = [...grid.querySelectorAll<HTMLAnchorElement>('.gallery-item')];
          const items = links.map((a) => ({ src: a.href, alt: a.querySelector('img')?.alt ?? '' }));

          let index = 0;
          let open = false;
          let opener: HTMLElement | null = null;

          const render = () => {
            view.src = items[index].src;
            view.alt = items[index].alt;
            counter.textContent = `${index + 1} / ${items.length}`;
          };
          const show = (i: number) => {
            index = (i + items.length) % items.length;
            render();
          };
          const openAt = (i: number) => {
            show(i);
            box.classList.add('is-open');
            document.body.style.overflow = 'hidden';
            box.querySelector<HTMLButtonElement>('[data-lb-next]')?.focus();
            if (!open) {
              open = true;
              // One history entry for the whole viewing session: Back closes it.
              history.pushState({ galleryLightbox: true }, '');
            }
          };
          const close = () => {
            box.classList.remove('is-open');
            document.body.style.overflow = '';
            open = false;
            opener?.focus();
          };
          // Close via UI → pop our pushed entry (which triggers the popstate close).
          const dismiss = () => (open ? history.back() : close());

          grid.addEventListener('click', (e) => {
            const a = (e.target as HTMLElement).closest<HTMLAnchorElement>('.gallery-item');
            if (!a) return;
            e.preventDefault();
            opener = a;
            openAt(links.indexOf(a));
          });
          box.querySelector('[data-lb-prev]')!.addEventListener('click', () => show(index - 1));
          box.querySelector('[data-lb-next]')!.addEventListener('click', () => show(index + 1));
          box.querySelectorAll('[data-lb-close]').forEach((el) => el.addEventListener('click', dismiss));
          window.addEventListener('popstate', () => open && close());
          document.addEventListener('keydown', (e) => {
            if (!open) return;
            if (e.key === 'Escape') dismiss();
            else if (e.key === 'ArrowRight') show(index + 1);
            else if (e.key === 'ArrowLeft') show(index - 1);
          });
        }
      </script>
    </Fragment>
  )
}

<style>
  .gallery-intro {
    color: var(--sl-color-gray-2);
  }

  /* Masonry: as many ≥260px columns as fit. Photos keep their natural ratio. */
  .gallery-masonry {
    columns: 260px 3;
    column-gap: 1rem;
    margin-top: 1.5rem;
  }
  .gallery-item {
    display: block;
    margin: 0 0 1rem;
    break-inside: avoid;
    overflow: hidden;
    border-radius: 9px;
    border: 1px solid var(--pc-code-border, var(--sl-color-gray-5));
    background: var(--pc-code-block, var(--sl-color-gray-6));
    box-shadow: var(--pc-code-shadow, none);
    cursor: zoom-in;
  }
  .gallery-item img {
    display: block;
    width: 100%;
    height: auto; /* natural aspect ratio — no cropping */
    transition: transform 0.25s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gallery-item:hover img {
      transform: scale(1.03);
    }
  }

  /* Lightbox — shown when the script adds .is-open (driven by JS, not the URL). */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .gallery-lightbox.is-open {
    display: flex;
  }
  /* The controls are <button>s — strip the native chrome. */
  .lb-backdrop,
  .lb-nav,
  .lb-close {
    appearance: none;
    font: inherit;
    cursor: pointer;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: color-mix(in srgb, var(--sl-color-black) 90%, transparent);
    cursor: zoom-out;
  }
  .lb-img {
    position: relative;
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 9px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.55);
  }

  .lb-nav,
  .lb-close {
    position: absolute;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-black) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-white) 22%, transparent);
    text-decoration: none;
    line-height: 1;
    transition:
      background-color 0.16s ease,
      transform 0.1s ease;
  }
  .lb-nav:hover,
  .lb-close:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 70%, transparent);
  }
  .lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 99rem;
    font-size: 1.75rem;
    padding-bottom: 0.15em;
  }
  .lb-prev {
    left: max(1rem, 3vw);
  }
  .lb-next {
    right: max(1rem, 3vw);
  }
  .lb-close {
    top: max(1rem, 3vw);
    right: max(1rem, 3vw);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9px;
    font-size: 1.5rem;
  }
  .lb-counter {
    position: absolute;
    bottom: max(1rem, 3vw);
    z-index: 1;
    padding: 0.25rem 0.7rem;
    border-radius: 99rem;
    font-family: var(--sl-font-display);
    font-size: 0.8125rem;
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-black) 55%, transparent);
  }

  .gallery-empty {
    color: var(--sl-color-gray-3);
    font-style: italic;
  }
</style>
