---
// Build-photo gallery body, shared by the en + zh pages (see src/pages/*/hardware-gallery).
//
// Photos are fetched into src/assets/gallery/ at build time by scripts/fetch-release.mjs
// and optimized here with astro:assets (sharp): a small webp thumbnail per photo plus a
// larger webp for the lightbox, so big originals never block the grid. The masonry
// layout keeps each photo's natural aspect ratio (no cropping). The lightbox is pure
// CSS (:target) — no client JS — with prev/next, a close affordance, and a counter.
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  lang?: 'en' | 'zh';
}
const { lang = 'en' } = Astro.props;

const STRINGS = {
  en: {
    intro: 'Real build photos of an assembled PhysiClaw rig.',
    empty: 'Gallery photos are being prepared — check back soon.',
    alt: (n: number) => `Assembled PhysiClaw rig — photo ${n}`,
    enlarge: (n: number) => `View photo ${n} full size`,
    prev: 'Previous photo',
    next: 'Next photo',
    close: 'Close',
  },
  zh: {
    intro: '组装完成的 PhysiClaw 硬件实物照片。',
    empty: '相册照片正在准备中，敬请期待。',
    alt: (n: number) => `已组装的 PhysiClaw — 照片 ${n}`,
    enlarge: (n: number) => `查看第 ${n} 张大图`,
    prev: '上一张',
    next: '下一张',
    close: '关闭',
  },
}[lang];

// Eagerly import every gallery image as ImageMetadata (width/height/format).
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.{png,jpg,jpeg,webp,avif,gif}',
  { eager: true },
);
const sources = Object.keys(modules)
  .sort()
  .map((k) => modules[k].default);

// Pre-render an optimized thumbnail + lightbox image for each photo.
const photos = await Promise.all(
  sources.map(async (src, i) => {
    const n = i + 1;
    const thumbW = Math.min(src.width, 900);
    const fullW = Math.min(src.width, 2000);
    const [thumb, full] = await Promise.all([
      getImage({ src, width: thumbW, format: 'webp' }),
      getImage({ src, width: fullW, format: 'webp' }),
    ]);
    return {
      n,
      thumbSrc: thumb.src,
      thumbW,
      thumbH: Math.round((thumbW * src.height) / src.width),
      fullSrc: full.src,
      prev: i === 0 ? sources.length : i, // 1-based id of previous (cyclic)
      next: i === sources.length - 1 ? 1 : i + 2,
    };
  }),
);
---

{
  photos.length === 0 ? (
    <p class="gallery-empty">{STRINGS.empty}</p>
  ) : (
    <Fragment>
      <p class="gallery-intro">{STRINGS.intro}</p>

      <div class="gallery-masonry">
        {photos.map((p) => (
          <a class="gallery-item" href={`#photo-${p.n}`} aria-label={STRINGS.enlarge(p.n)}>
            <img
              src={p.thumbSrc}
              width={p.thumbW}
              height={p.thumbH}
              alt={STRINGS.alt(p.n)}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>

      {photos.map((p) => (
        <div class="gallery-lightbox" id={`photo-${p.n}`}>
          <a class="lb-backdrop" href="#_" aria-label={STRINGS.close} />
          <a class="lb-nav lb-prev" href={`#photo-${p.prev}`} aria-label={STRINGS.prev}>
            ‹
          </a>
          <img class="lb-img" src={p.fullSrc} alt={STRINGS.alt(p.n)} loading="lazy" decoding="async" />
          <a class="lb-nav lb-next" href={`#photo-${p.next}`} aria-label={STRINGS.next}>
            ›
          </a>
          <a class="lb-close" href="#_" aria-label={STRINGS.close}>
            ×
          </a>
          <span class="lb-counter">
            {p.n} / {photos.length}
          </span>
        </div>
      ))}
    </Fragment>
  )
}

<style>
  .gallery-intro {
    color: var(--sl-color-gray-2);
  }

  /* Masonry: as many ≥260px columns as fit. Photos keep their natural ratio. */
  .gallery-masonry {
    columns: 260px 3;
    column-gap: 1rem;
    margin-top: 1.5rem;
  }
  .gallery-item {
    display: block;
    margin: 0 0 1rem;
    break-inside: avoid;
    overflow: hidden;
    border-radius: 9px;
    border: 1px solid var(--pc-code-border, var(--sl-color-gray-5));
    background: var(--pc-code-block, var(--sl-color-gray-6));
    box-shadow: var(--pc-code-shadow, none);
    cursor: zoom-in;
  }
  .gallery-item img {
    display: block;
    width: 100%;
    height: auto; /* natural aspect ratio — no cropping */
    transition: transform 0.25s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gallery-item:hover img {
      transform: scale(1.03);
    }
  }

  /* Pure-CSS lightbox — visible only when its id is the URL :target. */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .gallery-lightbox:target {
    display: flex;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--sl-color-black) 90%, transparent);
    cursor: zoom-out;
  }
  .lb-img {
    position: relative;
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 9px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.55);
  }

  .lb-nav,
  .lb-close {
    position: absolute;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-black) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-white) 22%, transparent);
    text-decoration: none;
    line-height: 1;
    transition:
      background-color 0.16s ease,
      transform 0.1s ease;
  }
  .lb-nav:hover,
  .lb-close:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 70%, transparent);
  }
  .lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 99rem;
    font-size: 1.75rem;
    padding-bottom: 0.15em;
  }
  .lb-prev {
    left: max(1rem, 3vw);
  }
  .lb-next {
    right: max(1rem, 3vw);
  }
  .lb-close {
    top: max(1rem, 3vw);
    right: max(1rem, 3vw);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9px;
    font-size: 1.5rem;
  }
  .lb-counter {
    position: absolute;
    bottom: max(1rem, 3vw);
    z-index: 1;
    padding: 0.25rem 0.7rem;
    border-radius: 99rem;
    font-family: var(--sl-font-display);
    font-size: 0.8125rem;
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-black) 55%, transparent);
  }

  .gallery-empty {
    color: var(--sl-color-gray-3);
    font-style: italic;
  }
</style>
