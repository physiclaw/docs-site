---
// Overrides Starlight's LanguageSelect (a native <select>) with a single toggle
// link. The site has two locales, so instead of a dropdown we show the *other*
// language's label and link straight to it: on an English page the button reads
// "中文", on a Chinese page it reads "English". The target URL is the current
// path with its leading locale segment swapped (matching Starlight's own
// localizedUrl behaviour for our prefixed locales).
import config from 'virtual:starlight/user-config';

const codes = Object.keys(config.locales ?? {});
const segments = Astro.url.pathname.split('/');
const currentCode = codes.includes(segments[1]) ? segments[1] : codes[0];

// The locale to switch to: the next one in the list, cycling back to the first.
// For our two-locale config this is simply "the other language".
const currentIndex = Math.max(0, codes.indexOf(currentCode));
const targetCode = codes[(currentIndex + 1) % codes.length];
const target = config.locales?.[targetCode];

/** Current path with its locale segment swapped to `code`. */
function hrefFor(code) {
  const segs = [...segments];
  if (codes.includes(segs[1])) segs[1] = code;
  else segs.splice(1, 0, code);
  return segs.join('/');
}
---

{
  config.isMultilingual && target && (
    <a
      class="lang-toggle"
      href={hrefFor(targetCode)}
      hreflang={target.lang}
      lang={target.lang}
      aria-label={Astro.locals.t('languageSelect.accessibleLabel')}
    >
      <svg class="globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10" />
        <path d="M2 12h20M12 2a15.3 15.3 0 0 1 0 20M12 2a15.3 15.3 0 0 0 0 20" />
      </svg>
      <span class="label">{target.label}</span>
    </a>
  )
}

<style>
  /* A single toggle link styled to match the header chrome. */
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    height: 2rem;
    padding-inline: 0.55rem;
    border-radius: 9px;
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-display);
    font-size: 0.8125rem;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    user-select: none;
    transition:
      background-color 0.16s ease,
      color 0.16s ease,
      transform 0.1s ease;
  }
  .lang-toggle:hover,
  .lang-toggle:focus-visible {
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--pc-paper) 68%, transparent);
  }
  /* Natural press: a brief scale-down on click. */
  @media (prefers-reduced-motion: no-preference) {
    .lang-toggle:active {
      transform: scale(0.94);
    }
  }
  .lang-toggle .globe {
    width: 1.05rem;
    height: 1.05rem;
  }
</style>
