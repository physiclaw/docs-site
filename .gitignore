src/content/docs

# Release artifacts fetched from physiclaw/PhysiClaw at build by scripts/fetch-release.mjs.
# Served from public/ but never committed — pulled fresh each build.
.release-cache
public/en/hardware/manual
public/zh/hardware/manual
public/en/hardware/sourcing-guide
public/zh/hardware/sourcing-guide
public/downloads
public/.release-version
# Build photos: fetched (pre-optimized) from the gallery release at build, never committed.
src/assets/gallery
# The optimized zip produced locally by scripts/optimize-gallery.mjs for upload to the release.
/physiclaw_hardware_gallery.zip
