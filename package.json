{
  "name": "physiclaw-docs-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/fetch-release.mjs && node scripts/sync-docs.mjs && astro dev",
    "sync:docs": "node scripts/sync-docs.mjs",
    "fetch:release": "node scripts/fetch-release.mjs",
    "prebuild": "node scripts/fetch-release.mjs && node scripts/sync-docs.mjs",
